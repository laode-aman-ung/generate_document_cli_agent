# Salin file ini menjadi .env
# API key tersedia di CleverDoc backend/.env

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Provider untuk generate konten: deepseek atau gemini
CONTENT_PROVIDER=deepseek

# Folder output dokumen
OUTPUT_DIR=output
